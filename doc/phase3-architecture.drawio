  <diagram id="hak-database" name="3. Database Schema">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t3" value="HAK Platform — Database Schema (3 Tables + Pinecone)" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- ═══ companies table ═══ -->
        <mxCell id="tbl-companies" value="" style="swimlane;startSize=0;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="300" height="500" as="geometry" />
        </mxCell>
        <mxCell id="tc-header" value="public.companies (existing)" style="text;html=1;fontSize=14;fontStyle=1;align=center;fillColor=#6c8ebf;fontColor=#ffffff;rounded=1;" vertex="1" parent="tbl-companies">
          <mxGeometry x="0" y="0" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tc-body" value="PK  id                 bigserial&#xa;UK  company_id          text NOT NULL&#xa;UK  sector              text NOT NULL&#xa;    name                text NOT NULL&#xa;    slug                text NOT NULL&#xa;    country             text NOT NULL&#xa;    company_type        text NOT NULL&#xa;    profile_url         text NOT NULL&#xa;    ─────── Phase 2 (sparse) ──────&#xa;    description         text&#xa;    website             text&#xa;    founded_year        integer&#xa;    address             text&#xa;    phone               text&#xa;    email               text&#xa;    employees_count     text&#xa;    executives          jsonb&#xa;    ─────── Timestamps ──────────&#xa;    listing_scraped_at  timestamptz&#xa;    detail_scraped_at   timestamptz&#xa;    created_at          timestamptz&#xa;    updated_at          timestamptz&#xa;&#xa;UNIQUE INDEX (company_id, sector)" style="text;html=0;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontFamily=monospace;" vertex="1" parent="tbl-companies">
          <mxGeometry x="0" y="35" width="300" height="460" as="geometry" />
        </mxCell>

        <!-- ═══ company_details table ═══ -->
        <mxCell id="tbl-details" value="" style="swimlane;startSize=0;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="80" width="360" height="760" as="geometry" />
        </mxCell>
        <mxCell id="td-header" value="public.company_details ★ NEW" style="text;html=1;fontSize=14;fontStyle=1;align=center;fillColor=#82b366;fontColor=#ffffff;rounded=1;" vertex="1" parent="tbl-details">
          <mxGeometry x="0" y="0" width="360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="td-body" value="PK  id                      uuid (gen_random_uuid)&#xa;FK  company_id               text NOT NULL&#xa;FK  sector                   text NOT NULL&#xa;    ──────── Identity (Tier 1) ────────&#xa;    name                     text NOT NULL&#xa;    domain                   text (unique partial)&#xa;    description              text&#xa;    description_clean         text (LLM cleaned)&#xa;    ──────── Location ──────────────&#xa;    country                  text&#xa;    country_code             text (AE)&#xa;    city                     text (Dubai)&#xa;    region                   text (GCC)&#xa;    ──────── Sector Classification ──&#xa;    sub_sector               text&#xa;    sub_sector_tags          text[]&#xa;    ──────── Size &amp; Stage ──────────&#xa;    funding_stage            text&#xa;    funding_total_usd        bigint&#xa;    headcount_range          text (51-200)&#xa;    headcount_exact          integer&#xa;    founded_year             integer&#xa;    ──────── Sector Signals ────────&#xa;    sector_metadata          jsonb {}&#xa;    ──────── Display &amp; Links ───────&#xa;    logo_url, linkedin_url   text&#xa;    crunchbase_url           text&#xa;    ──────── Source IDs (future) ───&#xa;    crunchbase_uuid          text&#xa;    pdl_id                   text&#xa;    linkedin_company_id      text&#xa;    ──────── Quality ──────────────&#xa;    data_quality_score       real (0-1)&#xa;    content_hash             text&#xa;    sources_used             text[]&#xa;    ──────── Pipeline State ───────&#xa;    enrichment_status        text (state machine)&#xa;    enrichment_error         text&#xa;    enrichment_version       integer&#xa;    ──────── Vector Sync ──────────&#xa;    pinecone_synced_at       timestamptz&#xa;    embedding_model          text&#xa;    ──────── Raw Audit Trail ──────&#xa;    raw_search_results       jsonb []&#xa;    raw_website_data         jsonb {}&#xa;    raw_llm_extraction       jsonb {}&#xa;    ──────── Timestamps ──────────&#xa;    last_enriched_at         timestamptz&#xa;    created_at               timestamptz&#xa;    updated_at               timestamptz&#xa;&#xa;FK → companies(company_id, sector)&#xa;UNIQUE INDEX (company_id, sector)&#xa;UNIQUE PARTIAL INDEX (domain)&#xa;GIN INDEX (sector_metadata)&#xa;GIN INDEX (sub_sector_tags)" style="text;html=0;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontFamily=monospace;" vertex="1" parent="tbl-details">
          <mxGeometry x="0" y="35" width="360" height="720" as="geometry" />
        </mxCell>

        <!-- ═══ company_scores table ═══ -->
        <mxCell id="tbl-scores" value="" style="swimlane;startSize=0;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="80" width="380" height="560" as="geometry" />
        </mxCell>
        <mxCell id="ts-header" value="public.company_scores ★ NEW" style="text;html=1;fontSize=14;fontStyle=1;align=center;fillColor=#82b366;fontColor=#ffffff;rounded=1;" vertex="1" parent="tbl-scores">
          <mxGeometry x="0" y="0" width="380" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ts-body" value="PK  id                               uuid&#xa;FK  company_detail_id                uuid NOT NULL&#xa;    company_id                       text (denorm)&#xa;    sector                           text (denorm)&#xa;    ──────── Dimension Scores (0-10) ────────&#xa;    organisational_scale_score       numeric(4,2)&#xa;    brand_prominence_score           numeric(4,2)&#xa;    leadership_depth_score           numeric(4,2)&#xa;    sector_fit_confidence_score      numeric(4,2)&#xa;    ──────── Confidence (0-1) ──────────────&#xa;    organisational_scale_confidence  numeric(3,2)&#xa;    brand_prominence_confidence      numeric(3,2)&#xa;    leadership_depth_confidence      numeric(3,2)&#xa;    sector_fit_confidence_confidence numeric(3,2)&#xa;    ──────── Evidence (JSONB) ──────────────&#xa;    organisational_scale_evidence    jsonb {}&#xa;    brand_prominence_evidence        jsonb {}&#xa;    leadership_depth_evidence        jsonb {}&#xa;    sector_fit_confidence_evidence   jsonb {}&#xa;    ──────── Composite ─────────────────────&#xa;    base_score                       numeric(5,2)&#xa;    ──────── Scoring Config Reference ──────&#xa;    scoring_config_id                text NOT NULL&#xa;    scoring_config_hash              text&#xa;    scoring_weights                  jsonb NOT NULL&#xa;    ──────── Versioning ───────────────────&#xa;    scoring_version                  integer (1)&#xa;    scored_at                        timestamptz&#xa;    created_at                       timestamptz&#xa;    updated_at                       timestamptz&#xa;&#xa;FK → company_details(id)&#xa;UNIQUE INDEX (company_detail_id, scoring_config_id)&#xa;INDEX (base_score DESC)&#xa;INDEX (sector, base_score DESC)" style="text;html=0;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontFamily=monospace;" vertex="1" parent="tbl-scores">
          <mxGeometry x="0" y="35" width="380" height="520" as="geometry" />
        </mxCell>

        <!-- ═══ Pinecone ═══ -->
        <mxCell id="tbl-pinecone" value="" style="swimlane;startSize=0;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1260" y="80" width="320" height="400" as="geometry" />
        </mxCell>
        <mxCell id="tp-header" value="Pinecone: hak-company-profiles ★" style="text;html=1;fontSize=14;fontStyle=1;align=center;fillColor=#9673a6;fontColor=#ffffff;rounded=1;" vertex="1" parent="tbl-pinecone">
          <mxGeometry x="0" y="0" width="320" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tp-body" value="Config:&#xa;  dimensions:  1536&#xa;  metric:      cosine&#xa;  model:       text-embedding-3-small&#xa;&#xa;Vector ID: {company_detail_id}&#xa;&#xa;Embedded Text (rich profile):&#xa;  Company name, sector, sub_sector&#xa;  Description (LLM-cleaned)&#xa;  Size, funding, location info&#xa;  Sector-specific signals&#xa;  All dimension scores + rationale&#xa;&#xa;Metadata (for filtering):&#xa;  company_id        str&#xa;  sector            str&#xa;  sub_sector        str&#xa;  country_code      str&#xa;  city              str&#xa;  region            str&#xa;  headcount_range   str&#xa;  funding_stage     str&#xa;  founded_year      int&#xa;  base_score        float&#xa;  *_score (4 dims)  float&#xa;  scoring_config_id str&#xa;  sub_sector_tags   str[]&#xa;  data_quality      float" style="text;html=0;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontFamily=monospace;" vertex="1" parent="tbl-pinecone">
          <mxGeometry x="0" y="35" width="320" height="360" as="geometry" />
        </mxCell>

        <!-- FK Arrows -->
        <mxCell id="fk-c-d" value="FK (company_id, sector)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;fontSize=9;" edge="1" source="tbl-details" target="tbl-companies" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fk-d-s" value="FK (company_detail_id)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;fontSize=9;" edge="1" source="tbl-scores" target="tbl-details" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sync-dp" value="embedded + synced" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;dashed=1;fontSize=9;" edge="1" source="tbl-scores" target="tbl-pinecone" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Relationship labels -->
        <mxCell id="rel1" value="1 : 1" style="text;fontSize=11;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="345" y="250" width="40" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rel2" value="1 : N" style="text;fontSize=11;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="770" y="250" width="40" height="20" as="geometry" />
