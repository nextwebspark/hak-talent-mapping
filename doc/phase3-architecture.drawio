  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- PAGE 2: SCORING MODEL (sector-specific, YAML configs) -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <diagram id="hak-scoring" name="2. Scoring Model">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t2" value="HAK Scoring Model — 4 Dimensions + Sector-Specific YAML Configs" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="700" height="40" as="geometry" />
        </mxCell>

        <!-- ═══ Dimension 1: Organisational Scale ═══ -->
        <mxCell id="d1" value="" style="swimlane;startSize=0;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="360" height="380" as="geometry" />
        </mxCell>
        <mxCell id="d1-title" value="Dimension 1: Organisational Scale" style="text;html=1;fontSize=16;fontStyle=1;align=center;fillColor=#82b366;fontColor=#ffffff;rounded=1;" vertex="1" parent="d1">
          <mxGeometry x="0" y="0" width="360" height="35" as="geometry" />
        </mxCell>
        <mxCell id="d1-weight" value="Default Weight: 25% (sector-configurable)" style="text;html=1;fontSize=12;fontStyle=1;align=center;fontColor=#82b366;" vertex="1" parent="d1">
          <mxGeometry x="0" y="40" width="360" height="25" as="geometry" />
        </mxCell>
        <mxCell id="d1-signals" value="SIGNALS&#xa;─────────────────────────&#xa;• Estimated headcount&#xa;  (LinkedIn, job boards, news)&#xa;• Number of locations&#xa;  (Google Maps, website, press)&#xa;• Revenue proxies&#xa;  (Annual reports, press)" style="text;html=0;fontSize=11;align=left;verticalAlign=top;spacingLeft=15;" vertex="1" parent="d1">
          <mxGeometry x="0" y="70" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="d1-formula" value="FORMULA&#xa;─────────────────────────&#xa;headcount_score = min(10, 2.5 × log₁₀(n+1))&#xa;location_score = min(10, 2.0 × log₁₀(n+1))&#xa;&#xa;scale = 0.50×headcount + 0.30×location&#xa;      + 0.20×revenue_bracket&#xa;&#xa;Note: logarithmic — caps the scale effect" style="text;html=0;fontSize=10;align=left;verticalAlign=top;spacingLeft=15;fontFamily=monospace;" vertex="1" parent="d1">
          <mxGeometry x="0" y="205" width="360" height="170" as="geometry" />
        </mxCell>

        <!-- ═══ Dimension 2: Brand Prominence ═══ -->
        <mxCell id="d2" value="" style="swimlane;startSize=0;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="80" width="360" height="380" as="geometry" />
        </mxCell>
        <mxCell id="d2-title" value="Dimension 2: Brand &amp; Market Prominence" style="text;html=1;fontSize=16;fontStyle=1;align=center;fillColor=#d6b656;fontColor=#ffffff;rounded=1;" vertex="1" parent="d2">
          <mxGeometry x="0" y="0" width="360" height="35" as="geometry" />
        </mxCell>
        <mxCell id="d2-weight" value="Default Weight: 20% (sector-configurable)" style="text;html=1;fontSize=12;fontStyle=1;align=center;fontColor=#d6b656;" vertex="1" parent="d2">
          <mxGeometry x="0" y="40" width="360" height="25" as="geometry" />
        </mxCell>
        <mxCell id="d2-signals" value="SIGNALS&#xa;─────────────────────────&#xa;• Media mention frequency (12 months)&#xa;  (News API, web search volume)&#xa;• Category leadership signals&#xa;  (&quot;largest&quot;, &quot;leading&quot;, &quot;first&quot;)&#xa;• Award / recognition mentions&#xa;• Regional expansion news" style="text;html=0;fontSize=11;align=left;verticalAlign=top;spacingLeft=15;" vertex="1" parent="d2">
          <mxGeometry x="0" y="70" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="d2-formula" value="FORMULA&#xa;─────────────────────────&#xa;For each mention:&#xa;  weight = 1.0 × 0.5^(months_ago / 12)&#xa;&#xa;raw = Σ(weighted_mentions)&#xa;prominence = min(10, normalize(raw))&#xa;&#xa;Note: recency decay — recent &gt; old" style="text;html=0;fontSize=10;align=left;verticalAlign=top;spacingLeft=15;fontFamily=monospace;" vertex="1" parent="d2">
          <mxGeometry x="0" y="205" width="360" height="170" as="geometry" />
        </mxCell>

        <!-- ═══ Dimension 3: Leadership Depth ═══ -->
        <mxCell id="d3" value="" style="swimlane;startSize=0;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="80" width="360" height="380" as="geometry" />
        </mxCell>
        <mxCell id="d3-title" value="Dimension 3: Leadership Depth" style="text;html=1;fontSize=16;fontStyle=1;align=center;fillColor=#6c8ebf;fontColor=#ffffff;rounded=1;" vertex="1" parent="d3">
          <mxGeometry x="0" y="0" width="360" height="35" as="geometry" />
        </mxCell>
        <mxCell id="d3-weight" value="Default Weight: 25% (sector-configurable)" style="text;html=1;fontSize=12;fontStyle=1;align=center;fontColor=#6c8ebf;" vertex="1" parent="d3">
          <mxGeometry x="0" y="40" width="360" height="25" as="geometry" />
        </mxCell>
        <mxCell id="d3-signals" value="SIGNALS&#xa;─────────────────────────&#xa;• C-suite / VP profiles visible&#xa;  (LinkedIn search by company + seniority)&#xa;• Named executives in press / website&#xa;• Executive tenure signals&#xa;• Functional breadth coverage&#xa;  (Commercial, Ops, Finance, Mktg, Tech, HR)" style="text;html=0;fontSize=11;align=left;verticalAlign=top;spacingLeft=15;" vertex="1" parent="d3">
          <mxGeometry x="0" y="70" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="d3-formula" value="FORMULA&#xa;─────────────────────────&#xa;exec_score = min(10, named_execs × 1.5)&#xa;&#xa;breadth_bonus:&#xa;  1-2 functions: +0&#xa;  3-4 functions: +1.0&#xa;  5-6 functions: +2.0&#xa;&#xa;leadership = min(10, exec_score + bonus)" style="text;html=0;fontSize=10;align=left;verticalAlign=top;spacingLeft=15;fontFamily=monospace;" vertex="1" parent="d3">
          <mxGeometry x="0" y="205" width="360" height="170" as="geometry" />
        </mxCell>

        <!-- ═══ Dimension 4: Sector Fit ═══ -->
        <mxCell id="d4" value="" style="swimlane;startSize=0;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="360" height="380" as="geometry" />
        </mxCell>
        <mxCell id="d4-title" value="Dimension 4: Sector Fit Confidence" style="text;html=1;fontSize=16;fontStyle=1;align=center;fillColor=#9673a6;fontColor=#ffffff;rounded=1;" vertex="1" parent="d4">
          <mxGeometry x="0" y="0" width="360" height="35" as="geometry" />
        </mxCell>
        <mxCell id="d4-weight" value="Default Weight: 30% (sector-configurable)" style="text;html=1;fontSize=12;fontStyle=1;align=center;fontColor=#9673a6;" vertex="1" parent="d4">
          <mxGeometry x="0" y="40" width="360" height="25" as="geometry" />
        </mxCell>
        <mxCell id="d4-signals" value="SIGNALS&#xa;─────────────────────────&#xa;• Primary activity matches sector&#xa;  (Company description, website, news)&#xa;• Country operational presence confirmed&#xa;  (Physical operations, local domain, press)&#xa;• Sub-sector classification&#xa;• Relevance type (Direct/Adjacent/Inferred)" style="text;html=0;fontSize=11;align=left;verticalAlign=top;spacingLeft=15;" vertex="1" parent="d4">
          <mxGeometry x="0" y="70" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="d4-formula" value="FORMULA&#xa;─────────────────────────&#xa;GATE: Is this company in {sector} in {country}?&#xa;  NO → score = 0 (confident exclusion)&#xa;  YES → continue&#xa;&#xa;Primary activity confirmed:  +4 pts&#xa;Country presence confirmed:  +3 pts&#xa;Sub-sector classifiable:    +3 pts&#xa;&#xa;sector_fit = gate × (p + c + s)" style="text;html=0;fontSize=10;align=left;verticalAlign=top;spacingLeft=15;fontFamily=monospace;" vertex="1" parent="d4">
          <mxGeometry x="0" y="205" width="360" height="170" as="geometry" />
        </mxCell>

        <!-- ═══ Base Score + Scoring Config ═══ -->
        <mxCell id="base" value="" style="swimlane;startSize=0;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="490" width="360" height="220" as="geometry" />
        </mxCell>
        <mxCell id="base-title" value="Base Score → company_scores table" style="text;html=1;fontSize=16;fontStyle=1;align=center;fillColor=#b85450;fontColor=#ffffff;rounded=1;" vertex="1" parent="base">
          <mxGeometry x="0" y="0" width="360" height="35" as="geometry" />
        </mxCell>
        <mxCell id="base-formula" value="base_score = (&#xa;  scale × weight_scale +&#xa;  prominence × weight_prominence +&#xa;  leadership × weight_leadership +&#xa;  sector_fit × weight_sector_fit&#xa;) × 10&#xa;&#xa;Range: 0 – 100&#xa;Weights from YAML: scoring_configs/{sector}_v1.yaml&#xa;&#xa;Stored with: scoring_config_id, scoring_weights,&#xa;scoring_config_hash (SHA256 for reproducibility)" style="text;html=0;fontSize=11;align=left;verticalAlign=top;spacingLeft=20;spacingTop=10;fontFamily=monospace;" vertex="1" parent="base">
          <mxGeometry x="0" y="40" width="360" height="180" as="geometry" />
        </mxCell>

        <!-- ═══ Sector Metadata ═══ -->
        <mxCell id="meta" value="" style="swimlane;startSize=0;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="490" width="360" height="280" as="geometry" />
        </mxCell>
        <mxCell id="meta-title" value="sector_metadata JSONB (per-sector signals)" style="text;html=1;fontSize=14;fontStyle=1;align=center;fillColor=#666666;fontColor=#ffffff;rounded=1;" vertex="1" parent="meta">
          <mxGeometry x="0" y="0" width="360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="meta-body" value="Retailers:&#xa;  store_count, brand_tier, online_presence,&#xa;  loyalty_program, franchise_model&#xa;&#xa;Software &amp; IT:&#xa;  tech_stack[], product_type, deployment_model,&#xa;  hiring_velocity, ml_hiring&#xa;&#xa;Healthcare:&#xa;  facility_count, specialties[], accreditations[],&#xa;  facility_type, bed_count&#xa;&#xa;Banking:&#xa;  license_type, assets_under_mgmt,&#xa;  digital_banking, branch_count&#xa;&#xa;Validated by per-sector Pydantic models.&#xa;Sectors without a model accept any dict." style="text;html=0;fontSize=10;align=left;verticalAlign=top;spacingLeft=15;spacingTop=5;" vertex="1" parent="meta">
          <mxGeometry x="0" y="35" width="360" height="240" as="geometry" />
        </mxCell>

        <!-- Arrows: dimensions → base score -->
        <mxCell id="ab1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;dashed=1;" edge="1" source="d1" target="base" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ab2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;dashed=1;" edge="1" source="d2" target="base" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ab3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;dashed=1;" edge="1" source="d3" target="base" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ab4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;dashed=1;" edge="1" source="d4" target="base" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

