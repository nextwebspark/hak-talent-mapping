        <!-- Stage 5: Profile Complete -->
        <mxCell id="s5" value="5. PROFILE COMPLETE&#xa;&#xa;Validate completeness&#xa;Compute quality score&#xa;Set content_hash&#xa;&#xa;Status: profile_complete" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=top;fontStyle=0;align=center;" vertex="1" parent="pipe-group">
